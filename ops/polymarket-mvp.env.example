# Polymarket-style MVP environment template
# Copy values selectively into your runtime env (Vercel/VM), do not commit secrets.

# --- Core trading APIs ---
POLY_CLOB_API_KEY=
POLY_CLOB_API_SECRET=
POLY_CLOB_API_PASSPHRASE=
POLY_CLOB_REST_URL=https://clob.polymarket.com
POLY_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws
POLY_CLOB_ENABLED=false
POLY_CLOB_DRY_RUN=true
POLY_CLOB_MAX_ORDERS_PER_CYCLE=2
POLY_CLOB_MICRO_SPLITS=2
POLY_CLOB_ORDER_USD=5
POLY_CLOB_ORDER_USD_MAX=20
POLY_CLOB_MIN_CONFIDENCE=0.56
POLY_CLOB_PRICE_CAP=0.62
POLY_CLOB_PRICE_FLOOR=0.38
POLY_CLOB_MIN_INTERVAL_SEC=120
POLY_CLOB_STATE_FILE=data/polymarket-clob-state.json
PREDICTION_MARKET_ENDPOINT=https://gamma-api.polymarket.com/markets?active=true&closed=false&limit=200

# --- Wallet / chain ---
WALLET_PRIVATE_KEY=
ALCHEMY_API_KEY=
ALCHEMY_NETWORK=base-mainnet

# --- Conversion routing ---
ZEROX_API_KEY=
CONVERSION_ENGINE_ENABLED=true
CONVERSION_ENGINE_DRY_RUN=true
CONVERSION_NETWORKS=base-mainnet
CONVERSION_FROM_TOKEN_BASE_MAINNET=0xEeeeeEeeeEeEeeEeEeEeeEEEeeeeEeeeeeeeEEeE
CONVERSION_TO_TOKEN_BASE_MAINNET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
CONVERSION_SELL_BALANCE_PCT_BASE_MAINNET=20
CONVERSION_MIN_NATIVE_RESERVE_ETH_BASE_MAINNET=0.01
CONVERSION_MIN_SELL_AMOUNT_WEI_BASE_MAINNET=100000000000000
CONVERSION_MIN_BUY_AMOUNT_WEI_BASE_MAINNET=500000
CONVERSION_SLIPPAGE_BPS_BASE_MAINNET=60
CONVERSION_ENGINE_MAX_TX_PER_CYCLE=1
CONVERSION_SPLIT_ORDERS=true
CONVERSION_SPLIT_MAX_PARTS=3
CONVERSION_SPLIT_BASE_BPS=2500
CONVERSION_STRENGTHEN_BPS=20
CONVERSION_SPLIT_MAX_SCALE_BPS=15000

# --- Risk controls ---
CASHFLOW_CIRCUIT_BREAKER_ENABLED=true
CASHFLOW_CIRCUIT_FAIL_SPIKE=3
CASHFLOW_CIRCUIT_NOGAS_SPIKE=3
CASHFLOW_CIRCUIT_MIN_SUCCESS_RATE=0.70
CASHFLOW_CIRCUIT_MIN_ATTEMPTS=4
CASHFLOW_CIRCUIT_REINVEST_BPS=7000

# --- Alerting ---
ALERT_WEBHOOK_URL=
ALERT_SECRET=
