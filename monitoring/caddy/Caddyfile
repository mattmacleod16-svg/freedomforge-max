{
    email {$CADDY_EMAIL}
}

# Local fallback when running without a public domain
http://localhost {
    reverse_proxy grafana:3000
}

# Production domain on Oracle VM
{$CADDY_DOMAIN} {
    @hasAuth expression `{env.CADDY_BASICAUTH_HASH} != ""`
    basicauth @hasAuth {
        admin {$CADDY_BASICAUTH_HASH}
    }

    reverse_proxy grafana:3000
}
